name = "xhalo-blog-api"
main = "src/index.js"
compatibility_date = "2026-06-01"

[vars]
LIVE_WRITES_ENABLED = "false"
ASSETS_PUBLIC_BASE_URL = "https://assets.example.com"
# GITHUB_OWNER = "your-github-username"
# GITHUB_REPO = "your-blog-repo"
# GITHUB_BRANCH = "main"
# ACCESS_TEAM_DOMAIN = "your-domain"
# ACCESS_AUDIENCE_TAG = "your-access-aud-tag"
# TURNSTILE_SITE_KEY = "your-turnstile-site-key"

[[d1_databases]]
binding = "DB"
database_name = "xhalo-blog"
database_id = "00000000-0000-0000-0000-000000000000"

[[r2_buckets]]
binding = "ASSETS"
bucket_name = "xhalo-blog-assets"

[[queues.producers]]
binding = "TASK_QUEUE"
queue = "xhalo-blog-tasks"
