{
  "name": "xhalo-blog",
  "version": "0.1.0-alpha.0",
  "private": true,
  "description": "Open-source Cloudflare-native Hexo blog framework scaffold.",
  "scripts": {
    "check": "node scripts/check-scaffold.mjs",
    "check:syntax": "node --check workers/api/src/index.js && node --check workers/queue/src/index.js",
    "check:secrets": "node scripts/check-no-production-markers.mjs",
    "build:admin": "npm --workspace apps/admin run build",
    "build:basic": "npm --workspace examples/basic-blog run build",
    "test": "node --test tests/*.test.mjs",
    "check:all": "npm run check && npm run build:admin && npm run build:basic && npm test && npm run check:syntax && npm run check:secrets"
  },
  "workspaces": [
    "apps/*",
    "workers/*",
    "packages/*",
    "examples/basic-blog"
  ],
  "engines": {
    "node": ">=20"
  }
}
