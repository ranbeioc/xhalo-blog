# wrangler.toml.example (Root Config representing the HTTP API Worker)
# To deploy the API worker, copy this file to wrangler.toml or use workers/api/wrangler.toml.example
# To deploy the Queue consumer, use the config under workers/queue/wrangler.toml.example

name = "xhalo-blog-api"
main = "workers/api/src/index.js"
compatibility_date = "2026-06-01"

[vars]
LIVE_WRITES_ENABLED = "false"
ASSETS_PUBLIC_BASE_URL = "https://assets.example.com"
PUBLISH_MODE = "pr_only"
OWNER_DIRECT_PUBLISH_ENABLED = "false"
OWNER_DIRECT_CONFIRMATION_PHRASE = "DIRECT PUBLISH TO MAIN"
OWNER_DIRECT_UPDATE_ENABLED = "false"
OWNER_DIRECT_UPDATE_CONFIRMATION_PHRASE = "DIRECT UPDATE EXISTING POST"

[[d1_databases]]
binding = "DB"
database_name = "xhalo-blog"
database_id = "00000000-0000-0000-0000-000000000000"

[[r2_buckets]]
binding = "ASSETS"
bucket_name = "xhalo-blog-assets"

[[queues.producers]]
binding = "TASK_QUEUE"
queue = "xhalo-blog-tasks"
