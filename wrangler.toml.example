name = "xhalo-blog-api"
main = "workers/api/src/index.js"
compatibility_date = "2026-06-01"

[[d1_databases]]
binding = "DB"
database_name = "xhalo_blog"
database_id = "00000000-0000-0000-0000-000000000000"

[[r2_buckets]]
binding = "ASSETS"
bucket_name = "xhalo-blog-assets"

[[queues.producers]]
binding = "PUBLISH_QUEUE"
queue = "xhalo-blog-publish"

[[queues.consumers]]
queue = "xhalo-blog-publish"
max_batch_size = 10
max_batch_timeout = 30
