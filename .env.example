# GitHub PR publishing
# Preferred GitHub App env for live draft publishing
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_INSTALLATION_ID=

# Fallback prototype token
GITHUB_TOKEN=

# Preview deployment reconciliation
PREVIEW_WEBHOOK_SECRET=
CLOUDFLARE_PAGES_DEPLOY_HOOK_URL=

# Turnstile
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Owner Direct Publish Mode (High-risk optional mode, disabled by default)
DEPLOYMENT_ENV=development
PUBLISH_MODE=pr_only
OWNER_DIRECT_PUBLISH_ENABLED=false
OWNER_DIRECT_CONFIRMATION_PHRASE=DIRECT PUBLISH TO MAIN
OWNER_DIRECT_UPDATE_ENABLED=false
OWNER_DIRECT_UPDATE_CONFIRMATION_PHRASE=DIRECT UPDATE EXISTING POST
OWNER_DIRECT_CONFIG_UPDATE_ENABLED=false
TEST_DIRECT_PUBLISH_ENABLED=false
TEST_TURNSTILE_BYPASS_ENABLED=false
TEST_MEDIA_UPLOAD_ENABLED=false
TEST_MEDIA_UPLOAD_PREFIX=xhalo-blog-test/

# GitHub OAuth Login Preview (Optional)
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
